name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  build-and-test:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build --if-present

      - name: Test
        run: npm test --if-present

To deploy:
# For each repo (Legacy-Circle and OurSpace-Vibes):
mkdir -p .github/workflows
# paste the above into .github/workflows/ci.yml, then:
git add .github/workflows/ci.yml
git commit -m "ci: add GitHub Actions CI workflow"
git push origin main

That's it — GitHub Actions will automatically run on every push and PR to main.
